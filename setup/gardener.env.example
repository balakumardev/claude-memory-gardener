# ~/.claude/gardener/gardener.env  —  sourced by the gardener shim.
# Point the BACKGROUND gardener at a cheap model so 3x/day batch distillation
# doesn't spend your interactive Claude budget. Nothing here is required; with
# an empty file the gardener just uses your normal `claude` auth + default model.
#
# ⚠️  NEVER put real secrets in the repo. This is only an EXAMPLE. Your actual
#     ~/.claude/gardener/gardener.env (with keys) stays local and is never
#     committed. Fill in your own values below.

# ── Option A: an Anthropic-compatible proxy (OpenLimits / OpenRouter / etc.) ──
# Routes to a cheap model via ANTHROPIC_* passthrough. The gardener keeps
# passing --model, so set GARDENER_MODEL too (see README env-var table).
# export ANTHROPIC_BASE_URL="https://your-proxy.example"
# export ANTHROPIC_API_KEY="sk-...redacted..."
# export GARDENER_MODEL="your-cheap-model-id"

# ── Option B: a local loopback router (claude-code-router / litellm) ──
# The shim pre-warms the router (launchd) and routes to it; the router's config
# decides the actual model, so we strip --model.
# export ANTHROPIC_BASE_URL="http://127.0.0.1:3456"
# export ANTHROPIC_AUTH_TOKEN="test"
# export ANTHROPIC_API_KEY=""
# export NO_PROXY="127.0.0.1"
# export ANTHROPIC_MODEL="opus"
# export GARDENER_STRIP_MODEL=1               # let the router pick the model
# export GARDENER_CCR_LABEL="com.$USER.ccr.opus"   # launchd label to kickstart
# export GARDENER_CCR_PORT="3456"                  # its health-check port

# ── Optional knobs (any setup) ──
# export GARDENER_MCP_TOOL="mcp__auggie-mcp__codebase-retrieval"  # append to --tools
# export GARDENER_GUARD_SECONDS=1800          # per-call wall-clock guard (default 30m)
# export GARDENER_CURATOR_MODEL="..."         # stronger model just for stage-2 curation
# export GARDENER_NO_CURATE=1                 # disable stage-2 skill/CLAUDE.md curation
# export GARDENER_CLAUDE_REAL="/absolute/path/to/claude"  # override auto-detected claude
