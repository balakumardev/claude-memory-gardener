#!/usr/bin/env bash
set -uo pipefail
# Memory Gardener scheduler entrypoint. Generated by setup.sh (do not edit here;
# edit setup/run.sh.template and re-run setup.sh). The gardener shim dir goes
# FIRST on PATH so the gardener's `claude` resolves to the routing shim.
export PATH="$HOME/.claude/gardener/bin:__NODE_BIN__/usr/bin:/bin:/usr/sbin:/sbin:/usr/local/bin:/opt/homebrew/bin"

# Catch-up gate: with RunAtLoad in the plist (macOS) / Persistent in the timer
# (Linux), the scheduler fires this at every login/boot too, so a run missed
# while the machine was off/asleep/logged-out still happens when you next log
# in. Skip if a run already happened in the last few hours — scheduled slots are
# >6h apart, so this never drops a real slot; it only suppresses redundant runs
# on frequent logins. Override the window with GARDENER_MIN_GAP_HOURS.
STAMP="$HOME/.claude/gardener/last-run"
if [ -f "$STAMP" ]; then
  now=$(date +%s)
  last=$(stat -f %m "$STAMP" 2>/dev/null || stat -c %Y "$STAMP" 2>/dev/null || echo 0)
  age=$(( (now - last) / 3600 ))
  if [ "$age" -lt "${GARDENER_MIN_GAP_HOURS:-4}" ]; then
    echo "gardener: last run ${age}h ago (< ${GARDENER_MIN_GAP_HOURS:-4}h) — skipping catch-up" >&2
    exit 0
  fi
fi
touch "$STAMP"

cd "__REPO__"
exec "__PYTHON__" -m gardener run
